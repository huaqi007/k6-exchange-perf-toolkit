{
  "name": "k6-exchange-perf-toolkit",
  "version": "1.0.0",
  "description": "k6 Exchange Performance Testing Toolkit - REST, WebSocket, gRPC, JSON-RPC multi-protocol load testing",
  "scripts": {
    "build": "webpack",
    "clean": "rm -rf dist",
    "mock": "node scripts/mock-server.js",
    "test:order": "k6 run dist/order-stress.js",
    "test:ws": "k6 run dist/market-data-ws.js",
    "test:grpc": "k6 run dist/grpc-service.js",
    "test:rpc": "k6 run dist/rpc-node.js",
    "test:e2e": "k6 run dist/e2e-trading.js",
    "test:matching": "k6 run dist/matching-engine.js",
    "test:cosmos": "k6 run dist/cosmos-query.js",
    "test:all": "bash scripts/run-all.sh",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.9.13",
    "@grpc/proto-loader": "^0.7.10",
    "express": "^4.18.2",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/k6": "^2.0.0",
    "glob": "^10.3.10",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "vitest": "^1.6.1",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
