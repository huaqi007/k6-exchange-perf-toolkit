{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ES2022",
    "lib": ["ES2017", "DOM"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "moduleResolution": "bundler",
    "allowJs": true,
    "types": ["k6"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
